# Supabase — copy to .env and fill in. The anon/publishable key is safe for the
# browser; auth, tenancy and RLS are all handled by Supabase (no other IdP).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-publishable-key

# Edge Function secrets (server-side only — set with `supabase secrets set`,
# NEVER expose to the browser). Used by invite-user (#58) and set-active-academy
# (#55). SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are
# injected automatically in the hosted Edge runtime; list here for local serve.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
